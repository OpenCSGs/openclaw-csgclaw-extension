{
  "name": "csgclaw-extension",
  "version": "0.3.9-ext.2",
  "description": "OpenClaw channel plugin: CSGClaw participant bridge (SSE + REST)",
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist", "openclaw.plugin.json"],
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openclaw": "2026.5.26",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.26"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "csgclaw": {
    "serverVersion": "0.3.9"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "csgclaw",
      "label": "CSGClaw",
      "selectionLabel": "CSGClaw (IM bridge)",
      "blurb": "Gateway connects to CSGClaw via participant SSE and REST.",
      "order": 15,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "csgclaw-extension",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.26"
    }
  }
}
